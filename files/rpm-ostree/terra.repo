[terra]
name=Terra $releasever
baseurl=https://repos.fyralabs.com/terra$releasever
enabled=1
gpgcheck=1
repo_gpgcheck=1
gpgkey=https://repos.fyralabs.com/terra$releasever/key.asc
# Prioridade acima do Fedora (99) para evitar sobrescrever pacotes oficiais.
# Apenas pacotes exclusivos do Terra (ex: Nerd Fonts) serão instalados.
priority=150
