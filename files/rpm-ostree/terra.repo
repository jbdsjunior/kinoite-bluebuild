[terra]
name=Terra $releasever
baseurl=https://repos.fyralabs.com/terra$releasever
enabled=1
gpgcheck=1
repo_gpgcheck=1
gpgkey=https://repos.fyralabs.com/terra$releasever/key.asc
# Priority lower than Fedora to avoid overriding official packages.
# Only Terra-exclusive packages (for example, Nerd Fonts) should be installed.
priority=150
